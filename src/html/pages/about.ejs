<section class="section sec02">
    <div class="section-inner">
        <h2 class="h2">ABOUT ME</h2>
        <div class="grid profile">
            <div class="profile-img">
                <%- include('../atoms/image.ejs', { imageSrc: 'profile.png', altText: 'profile image' }) %>
            </div>
            <div class="profile-box">
                <h3 class="profile-title">
                    안녕하세요!😀<br>
                    <em>차분함</em>과 <em>꾸준함</em>을 바탕으로<br>
                    <em>구조를 이해하고 탐구</em>하는<br>
                    웹 퍼블리셔 <strong>박혜준</strong>입니다.
                </h3>
                <div class="btn-wrap">
                    <%- include('../atoms/button.ejs', {
                        tag: 'a',
                        href: 'https://m.site.naver.com/1XPa9',
                        text: 'Notion 바로가기',
                        className: 'primary lg'
                    }) %>
                    <%- include('../atoms/button.ejs', {
                        tag: 'a',
                        href: 'https://m.site.naver.com/1Zfaw',
                        text: 'Vue 버전 바로가기',
                        className: 'primary lg'
                    }) %>
                </div>
            </div>
        </div>
        <div class="grid">
            <div class="about-box split">
                <h3 class="h3">SKILL & TOOL</h3>
                <div class="tool-list">
                <%
                    const tools = [
                    { src: '/tool/tool_logo01.png', alt: 'html' },
                    { src: '/tool/tool_logo02.png', alt: 'css' },
                    { src: '/tool/tool_logo03.png', alt: 'javascript' },
                    { src: '/tool/tool_logo04.png', alt: 'jQuery' },
                    { src: '/tool/tool_logo05.png', alt: 'vscode' },
                    { src: '/tool/tool_logo06.png', alt: 'vue' },
                    { src: '/tool/tool_logo07.png', alt: 'git' },
                    { src: '/tool/tool_logo08.png', alt: 'gulp' },
                    { src: '/tool/tool_logo09.png', alt: 'node js' },
                    { src: '/tool/tool_logo10.png', alt: 'bootstrap' },
                    { src: '/tool/tool_logo11.png', alt: 'tailwind' },
                    { src: '/tool/tool_logo12.png', alt: 'figma' },
                    { src: '/tool/tool_logo13.png', alt: 'photoshop' },
                    { src: '/tool/tool_logo14.png', alt: 'illustrator' },
                    { src: '/tool/tool_logo15.png', alt: 'adobe xd' },
                    { src: '/tool/tool_logo16.png', alt: 'zeplin' },
                    { src: '/tool/tool_logo17.png', alt: 'notion' },
                    { src: '/tool/tool_logo18.png', alt: 'slack' },
                ];
                %>
                <% tools.forEach(tool => { %>
                    <div>
                        <%- include('../atoms/image.ejs', { imageSrc: tool.src, altText: tool.alt }) %>
                    </div>
                <% }) %>

                </div>
            </div>
            <div class="about-box split">
                <h3 class="h3">Certifications</h3>
                <ul class="list-dot">
                    <li>컴퓨터활용능력 2급 (2024.02)</li>
                    <li>GTQ 일러스트 1급 (2018.03)</li>
                    <li>GTQ 1급 (2018.02)</li>
                    <li>컴퓨터그래픽스 운용기능사 (2008.06)</li>
                    <li>웹디자인 기능사 (2007.06)</li>
                </ul>
            </div>
        </div>
    </div>
</section>
